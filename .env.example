# Extoboost Root Configuration
# Copy to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/extoboost

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Secrets (min 32 chars)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
SESSION_SECRET=change-this-to-another-random-secret-at-least-32

# Ad Networks
LINKVERTISE_API_KEY=your-linkvertise-api-key
LINKVERTISE_PUBLISHER_ID=your-linkvertise-publisher-id
LOOTLABS_API_KEY=your-lootlabs-api-key
LOOTLABS_PUBLISHER_ID=your-lootlabs-publisher-id

# URLs
WEB_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
